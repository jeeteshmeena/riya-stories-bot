# === Required (minimal bot run) ===
BOT_TOKEN=your_bot_token

# === Channel / Group IDs (ints) ===
CHANNEL_ID=your_channel_id
GROUP_ID=your_group_id
ADMIN_ID=your_admin_id
OWNER_ID=your_owner_id
REQUEST_GROUP=your_request_group
LOG_CHANNEL=your_log_channel

# === Optional ===
COPYRIGHT_CHANNEL=your_copyright_channel

# === For /scan and auto-scan (Telethon) ===
API_ID=your_api_id
API_HASH=your_api_hash
SESSION_STRING=your_session_string

# === Deployment ===
AUTO_SCAN=true
RUN_HTTP_SERVER=false
DATA_DIR=.

# Get SESSION_STRING: run generate_session.py locally with API_ID/API_HASH from https://my.telegram.org
