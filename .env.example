# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABCDEF_your_bot_token

# Telegram channel/group IDs (use numeric IDs, usually negative for channels/groups)
CHANNEL_ID=-1001234567890
REQUEST_GROUP=-1001234567891
COPYRIGHT_CHANNEL=-1001234567892
LOG_CHANNEL=-1001234567893

# Admin user IDs
ADMIN_ID=123456789
OWNER_ID=123456789

# Telethon API credentials from https://my.telegram.org
API_ID=12345678
API_HASH=0123456789abcdef0123456789abcdef

# Generated via python generate_session.py
SESSION_STRING=YOUR_TELETHON_SESSION_STRING

# Optional settings
AUTO_SCAN=true
SEARCH_LIMIT=5
BOT_LANGUAGE=english
